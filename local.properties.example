# Example local.properties — copy to `local.properties` and fill in your own values.
#
# 1. sdk.dir  : path to your Android SDK install (Android Studio will write this
#               automatically when you open the project — you usually don't need
#               to set it by hand).
# 2. TMDB_API_KEY : a v3 API key from https://www.themoviedb.org/settings/api
#                    Required for "Search by name" mode. "TMDB ID direct" mode
#                    also uses it to fetch the title (extensions expect both
#                    title + tmdbId in the scrape URI).
sdk.dir=/home/your-user/Android/Sdk
TMDB_API_KEY=your_tmdb_v3_api_key_here
